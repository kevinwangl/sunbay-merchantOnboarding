<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Merchant Boarding — System Architecture" style="text;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="100" y="10" width="500" height="30" as="geometry"/>
    </mxCell>

    <!-- Import Merchant -->
    <mxCell id="import" value="Import&#xa;Merchant" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="20" y="145" width="100" height="50" as="geometry"/>
    </mxCell>

    <!-- IRIS CRM -->
    <mxCell id="iris" value="IRIS CRM" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="120" width="130" height="100" as="geometry"/>
    </mxCell>


    <!-- Import → IRIS -->
    <mxCell id="e1" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333333;" edge="1" parent="1" source="import" target="iris">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- OnBoarding Service Middleware -->
    <mxCell id="middleware" value="OnBoarding Service&#xa;Middleware" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;shadow=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="120" width="170" height="100" as="geometry"/>
    </mxCell>

    <!-- Label: Subscribe Merchant Events -->
    <mxCell id="lbl_subscribe" value="Subscribe Merchant Events" style="text;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#333333;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="120" width="170" height="18" as="geometry"/>
    </mxCell>

    <!-- IRIS → SUNBAY arrow -->
    <mxCell id="e2" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333333;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="iris" target="middleware">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Label: Sync Processor Merchant Data -->
    <mxCell id="lbl_sync" value="Sync Processor Merchant Data" style="text;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="200" width="170" height="18" as="geometry"/>
    </mxCell>

    <!-- SUNBAY → IRIS arrow -->
    <mxCell id="e2b" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf;dashed=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="middleware" target="iris">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- TSYS -->
    <mxCell id="tsys" value="TSYS" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="720" y="75" width="110" height="40" as="geometry"/>
    </mxCell>

    <!-- Elavon -->
    <mxCell id="elavon" value="Elavon" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="720" y="135" width="110" height="40" as="geometry"/>
    </mxCell>

    <!-- Fiserv (container with CardConnect + MID/TID) -->
    <mxCell id="fiserv" value="Fiserv" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;shadow=1;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
      <mxGeometry x="720" y="195" width="110" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="fiserv_cc" value="CardConnect" style="rounded=0;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="730" y="222" width="90" height="22" as="geometry"/>
    </mxCell>
    <mxCell id="fiserv_mid" value="Returns:&#xa;MID / TID" style="rounded=0;fillColor=#fff;strokeColor=#b85450;fontSize=10;fontStyle=1;fontColor=#b85450;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="730" y="250" width="90" height="30" as="geometry"/>
    </mxCell>

    <!-- Fiserv sub-processors -->
    <mxCell id="omaha" value="Omaha" style="rounded=0;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="855" y="195" width="70" height="22" as="geometry"/>
    </mxCell>
    <mxCell id="nashville" value="Nashville" style="rounded=0;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="855" y="222" width="70" height="22" as="geometry"/>
    </mxCell>
    <mxCell id="north" value="North" style="rounded=0;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="855" y="249" width="70" height="22" as="geometry"/>
    </mxCell>
    <mxCell id="e_fiserv_omaha" style="endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="fiserv" target="omaha">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_fiserv_nash" style="endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="fiserv" target="nashville">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_fiserv_north" style="endArrow=classic;strokeColor=#82b366;" edge="1" parent="1" source="fiserv" target="north">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Middleware → TSYS -->
    <mxCell id="e_mw_tsys" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=1.5;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="middleware" target="tsys">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Middleware → Elavon -->
    <mxCell id="e_mw_elavon" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="middleware" target="elavon">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Middleware → Fiserv -->
    <mxCell id="e_mw_fiserv" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=1.5;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="middleware" target="fiserv">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
